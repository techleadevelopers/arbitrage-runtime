# Runtime load-test example.
#
# Copy these variables into your shell session when regenerating benchmark
# artifacts. Do not put private keys or RPC credentials in benchmark artifacts.

RUST_LOG=error
NETWORK=polygon
RUN_RUNTIME_LOAD_TEST=true
RUNTIME_LOAD_TEST_CASES=100000
RUNTIME_LOAD_TEST_CONCURRENCY=4
RUNTIME_LOAD_TEST_LATENCY_BUDGET_US=250

# Use one profile at a time:
RUNTIME_LOAD_TEST_PROFILE=baseline
RUNTIME_LOAD_TEST_OUTPUT_PATH=runtime_baseline_report.json

# RUNTIME_LOAD_TEST_PROFILE=adversarial
# RUNTIME_LOAD_TEST_OUTPUT_PATH=runtime_adversarial_report.json
