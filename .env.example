NETWORK=bsc
CHAIN_ID=56
ALLOW_SEND=false
USE_TENDERLY_RPC_ONLY=false


MEV_EVM_PREFLIGHT_ENABLED=true
MEV_EVM_PREFLIGHT_HARD_FAIL=true

ALCHEMY_KEY=your_alchemy_key
ALCHEMY_KEY_2=
ALCHEMY_KEY_3=
FLASHBOTS_RELAY=
BUILDER_RELAYS=
RPC_READ_PREFERENCE=auto
RPC_SEND_PREFERENCE=auto
MEV_PENDING_LOOKUP_FANOUT=1
MEV_PENDING_LOOKUP_MAX_PER_SEC=60
MEV_BLOCK_LOOKUP_FANOUT=1
MEV_PAYLOAD_BUILD_FANOUT=1
MEV_SCAVENGER_SHADOW_NEGATIVE_TOLERANCE_USD=15
RPC_URL_BSC=
GETBLOCK_RPC_URL_BSC=
# Backward-compatible alias accepted by the runtime:
GETBLOCK_BNB=
MEMPOOL_WS_URL=
STORAGE_PATH=bot_state.sqlite
# Optional cloud storage. If set, the runtime uses Postgres instead of SQLite.
DATABASE_URL=
# Local default. On Railway you can omit DASHBOARD_ADDR and set PORT=8080; the app binds 0.0.0.0:$PORT automatically.
DASHBOARD_ADDR=127.0.0.1:8787

EXECUTOR_PRIVATE_KEY=0xyour_executor_private_key
# Initial two-wallet layout:
# - EXECUTOR_PRIVATE_KEY is the hot wallet with native gas.
# - CONTROL/VAULT/PROFIT can point to the same cold wallet during bootstrap.
CONTROL_ADDRESS=0x0000000000000000000000000000000000000001
VAULT_ADDRESS=0x0000000000000000000000000000000000000001
PROFIT_ADDRESS=0x0000000000000000000000000000000000000001

MEV_ENGINE_ENABLED=true
# conservative preserves capital; scavenger/farelo opens the funnel for low-value frequent extraction.
MEV_OPPORTUNITY_MODE=conservative
MEV_CAPITAL_ETH=0.05
MEV_MIN_NET_PROFIT_ETH=0.0025
MEV_MIN_PROFIT_USD=2.0
MEV_MIN_ROI_BPS=1500
MEV_MIN_LARGE_SWAP_ETH=25.0
MEV_MAX_PENDING_AGE_MS=1500
MEV_MAX_GAS_PER_TX=260000
# Fallback cap when no network-specific value is set.
MEV_MAX_GAS_PRICE_GWEI=
# Recommended caps by network.
MEV_MAX_GAS_PRICE_GWEI_BSC=4
MEV_MAX_GAS_PRICE_GWEI_BNB=4
MEV_MAX_GAS_PRICE_GWEI_POLYGON=80
MEV_LATENCY_TRACE=false
MEV_LATENCY_TRACE_WARN_US=5000
MEV_MAX_PRICE_IMPACT_BPS=250
MEV_SLIPPAGE_PROTECTION_BPS=50
MEV_ETH_USD_PRICE=3200.0
MEV_MIN_LIQUIDITY_ETH=25.0
MEV_GAS_SAFETY_MARGIN_BPS=12500

MEV_CAPITAL_WINDOW_SECS=90
MEV_MAX_WINDOW_EXPOSURE_ETH=0.15
MEV_MAX_CLUSTER_WINDOW_EXPOSURE_ETH=0.08
MEV_MAX_PAIR_WINDOW_EXPOSURE_ETH=0.10
MEV_RELAY_FANOUT_COUNT=3
MEV_RPC_FANOUT_COUNT=2
MEV_GAS_OVERPAY_BASE_EXTRA_BPS=500
MEV_GAS_OVERPAY_MISS_EXTRA_BPS=2500
MEV_GAS_OVERPAY_REVERT_EXTRA_BPS=1200
MEV_GAS_OVERPAY_SUBMIT_FAILURE_EXTRA_BPS=1500
MEV_GAS_OVERPAY_MAX_EXTRA_BPS=5000
MEV_STOP_LOSS_CONSECUTIVE_LOSSES=3
MEV_STOP_LOSS_FREEZE_SECS=300
MEV_CONTEXT_STOP_LOSS_CONSECUTIVE_LOSSES=2
MEV_CONTEXT_STOP_LOSS_FREEZE_SECS=180
MEV_CAPITAL_MULTIPLIER_AGGRESSIVE=2.0
MEV_CAPITAL_MULTIPLIER_NEUTRAL=1.0
MEV_CAPITAL_MULTIPLIER_DEFENSIVE=0.3
MEV_CAPITAL_MULTIPLIER_PRIORITY_THRESHOLD=0.60
MEV_CAPITAL_MULTIPLIER_TOXICITY_THRESHOLD=0.65

MEV_EXECUTOR_MIN_BUFFER_ETH=0.20
MEV_EXECUTOR_TARGET_BUFFER_ETH=0.50
MEV_EXECUTOR_MAX_BUFFER_ETH=1.00

MEV_UNISWAP_V2_FACTORY=
MEV_UNISWAP_V3_FACTORY=
MEV_EXECUTOR_ADDRESS=

MONITORED_TOKENS_BSC=WBNB:0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c:18:1.0
MONITORED_TOKENS_POLYGON=WPOL:0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270:18:1.0
MONITORED_TOKENS_ETHEREUM=WETH:0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2:18:1.0
MONITORED_TOKENS_ARBITRUM=WETH:0x82aF49447D8a07e3bd95BD0d56f35241523fBab1:18:1.0

RUN_NETWORK_BENCHMARK=false
RUN_REPLAY_HARNESS=false
REPLAY_INPUT_PATH=
REPLAY_LIMIT=500
REPLAY_OUTPUT_PATH=
REPLAY_AUTO_TUNE=false
REPLAY_AUTO_TUNE_APPLY=false
REPLAY_AUTO_TUNE_APPLY_PATH=
REPLAY_AUTO_TUNE_USE_IN_RUNTIME=false
REPLAY_AUTO_TUNE_RUNTIME_ENV_PATH=
REPLAY_TUNE_THRESHOLD_MULTIPLIERS=0.90,1.00,1.10
REPLAY_TUNE_PRIORITY_SHIFTS=-0.05,0.00,0.05
REPLAY_TUNE_TOXICITY_SHIFTS=-0.05,0.00,0.05
REPLAY_TUNE_GAS_EXTRA_BPS=0,500,1000,2000
REPLAY_TUNE_OUTPUT_PATH=
FREEZE_REFERENCE_ARTIFACTS=false
REFERENCE_ARTIFACTS_DIR=

TENDERLY_FORK_URL_BNB=
TENDERLY_FORK_URL_POLYGON=
TENDERLY_FORK_URL_ETHEREUM=
TENDERLY_FORK_URL_ARBITRUM=
